# Copy to .env (gitignored) or export before running.
# Get a key at https://console.anthropic.com/
#
# Only AI alt text and the optional vision suggestions need this key.
# Everything else (index, browse, local add, PIAF prep, image edits) works without it.
ANTHROPIC_API_KEY=

# Optional: the folder this app indexes. Defaults to the bundled ./sample-archive.
# Point it at your real archive (it is never reorganized — only metadata is written alongside).
#   ARCHIVE_DIR=/Users/you/Dropbox/precedents
ARCHIVE_DIR=
