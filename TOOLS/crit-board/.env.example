# crit-board configuration — copy to `.env` and edit. `.env` is gitignored.

# Two shared passcodes for the studio (any non-empty strings).
# Students enter the student passcode, then pick their name from the roster.
# Instructors enter the instructor passcode to unlock admin + moderation.
STUDENT_PASSCODE=change-me-students
INSTRUCTOR_PASSCODE=change-me-instructor

# Secret used to sign the session cookie. Use a long random value in production, e.g.
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=please-generate-a-long-random-value

# Where the SQLite DB + uploaded images live. MUST be a persistent, mounted disk in prod
# (otherwise images + the DB are wiped on every redeploy). Defaults to ./data locally.
DATA_DIR=./data

# Port the server listens on (hosting platforms usually inject this automatically).
PORT=3000

# Max upload size per image, in megabytes.
MAX_UPLOAD_MB=25
