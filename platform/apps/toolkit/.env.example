# Toolkit app — copy to .env.local and fill in.

# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Anthropic — server-side only, never exposed to the browser.
# Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Public base URL of THIS app (used to build the magic-link redirect).
# Local: http://localhost:3000 — Production: https://toolkit.yourdomain
NEXT_PUBLIC_SITE_URL=http://localhost:3000
