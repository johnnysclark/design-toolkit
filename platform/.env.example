# Workshop platform — environment template. Copy to .env for local dev.
# NO real secrets are committed; .env is gitignored at the repo root.

# Required for the model passes. Without it the UI loads but /api/*/ask fails.
ANTHROPIC_API_KEY=sk-ant-...

# Postgres connection string. Locally e.g. postgres://localhost:5432/workshop
# On Render this is injected automatically from the managed database.
DATABASE_URL=postgres://localhost:5432/workshop

# Seeds one class on migrate so students can join immediately.
CLASS_CODE=STUDIO1
CLASS_NAME=Fall Studio

# Gates the instructor dashboard + analytics endpoints. Pick something long.
INSTRUCTOR_PASSWORD=change-me

# Optional. Render injects PORT; locally defaults to 3000.
PORT=3000
